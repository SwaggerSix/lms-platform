# =============================================================================
# Supabase (Required)
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# =============================================================================
# Email (Resend)
# =============================================================================
# Resend: Set RESEND_API_KEY and emails will send via Resend.
# Get your API key at https://resend.com/api-keys
RESEND_API_KEY=re_your_key
EMAIL_FROM=LMS Platform <noreply@yourdomain.com>

# =============================================================================
# Cron Jobs
# =============================================================================
# Secret used to authenticate Vercel Cron requests.
# Generate with: openssl rand -base64 32
CRON_SECRET=your-random-secret

# =============================================================================
# SurveyCraft integration (Evaluations & Assessments)
# =============================================================================
# Base URL of the SurveyCraft app. Embedded surveys load from {BASE}/s/{slug}.
SURVEYCRAFT_BASE_URL=https://surveycraft.yourdomain.com
# Shared secret used to sign the embed/correlation token (?lt=) sent to SurveyCraft.
# Generate with: openssl rand -base64 32
EVALUATION_EMBED_SECRET=your-embed-secret
# Shared secret SurveyCraft uses to HMAC-sign inbound completion webhooks.
# Must match the value configured on the SurveyCraft side.
LMS_WEBHOOK_SECRET=your-webhook-secret

# =============================================================================
# Mentorship onboarding gate (optional)
# =============================================================================
# If set to a course UUID, a user must have completed that course before
# their mentor profile is allowed to be active. Leave unset to disable the gate.
# MENTOR_ONBOARDING_COURSE_ID=00000000-0000-0000-0000-000000000000

# =============================================================================
# Application
# =============================================================================
NEXT_PUBLIC_APP_URL=https://your-domain.com
