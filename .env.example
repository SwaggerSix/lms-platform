# ─── Partner Portal sync (subcontractor → instructor) ───
# Shared secret the gC Partner Portal presents (as a Bearer token) when it
# pushes a profile-change webhook to /api/integrations/partner-portal/webhook.
# Must match the portal's PARTNER_PORTAL_WEBHOOK_SECRET / lms_sync_config.webhook_secret.
PARTNER_PORTAL_WEBHOOK_SECRET=replace-with-a-long-random-string

# Note: the LMS → portal read-API credentials (the portal base URL and the
# shared read secret) are NOT env vars — they live in the
# external_integrations row (provider = 'partner_portal') config JSON:
#   { "api_base": "https://partners.gothamculture.com", "api_secret": "<LMS_SYNC_API_SECRET>" }

# ─── QuickBooks Bridge pull/ack API ───
# Shared bearer token the QB Bridge (gc-partner-portal) presents when it pulls
# queued events from /api/integrations/qb-bridge/pending and acks results to
# /api/integrations/qb-bridge/ack. Compared timing-safely; it is the security
# boundary for those machine-to-machine routes (they bypass RLS). Must match
# the Bridge's configured token.
QB_BRIDGE_TOKEN=replace-with-a-long-random-string
