# ─── Partner Portal sync (subcontractor → instructor) ───
# Shared secret the gC Partner Portal presents (as a Bearer token) when it
# pushes a profile-change webhook to /api/integrations/partner-portal/webhook.
# Must match the portal's PARTNER_PORTAL_WEBHOOK_SECRET / lms_sync_config.webhook_secret.
PARTNER_PORTAL_WEBHOOK_SECRET=replace-with-a-long-random-string

# Note: the LMS → portal read-API credentials (the portal base URL and the
# shared read secret) are NOT env vars — they live in the
# external_integrations row (provider = 'partner_portal') config JSON:
#   { "api_base": "https://partners.gothamculture.com", "api_secret": "<LMS_SYNC_API_SECRET>" }

# ─── Two-way profile write-back (instructor edits → portal) ───
# When a portal-synced instructor edits a portal-owned field (name, email, bio,
# avatar) in the LMS, the change is POSTed back to the portal (system of record),
# which re-syncs the canonical value here and to CoachHub.
# URL of the portal write-back ingest endpoint:
PARTNER_PORTAL_WRITEBACK_URL=https://partners.gothamculture.com/api/integrations/profile-writeback
# Shared secret, must match the portal's PROFILE_WRITEBACK_SECRET:
PROFILE_WRITEBACK_SECRET=replace-with-a-long-random-string

# ─── Registration policy (S6) ───
# Controls who may self-provision an account via /api/auth/register.
#   open   → anyone with a valid Supabase auth user (default; current behaviour)
#   domain → only email addresses in REGISTRATION_ALLOWED_DOMAINS
#   closed → self-registration disabled (invite-only)
REGISTRATION_MODE=open
# Comma-separated allowlist used when REGISTRATION_MODE=domain, e.g.
# gothamculture.com,gothamgovernment.com
REGISTRATION_ALLOWED_DOMAINS=

# ─── Durable rate limiting (S5) ───
# Login/registration rate limits fall back to per-instance in-memory counters
# unless Upstash Redis is configured. On serverless (Vercel) those counters
# reset on cold start and are per-instance, so brute-force protection is weak
# at scale. Set both to make rate limiting durable and shared across instances.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── QuickBooks Bridge pull/ack API ───
# Shared bearer token the QB Bridge (gc-partner-portal) presents when it pulls
# queued events from /api/integrations/qb-bridge/pending and acks results to
# /api/integrations/qb-bridge/ack. Compared timing-safely; it is the security
# boundary for those machine-to-machine routes (they bypass RLS). Must match
# the Bridge's configured token.
QB_BRIDGE_TOKEN=replace-with-a-long-random-string
